rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: reports
// Document ID: {sessionId} — UUID generated by orchestrator
// Fields:
//   - uid: string (required, immutable) — Firebase Auth UID of session owner (or "anonymous")
//   - hypothesis: string (required, 20-2000 chars) — raw user input
//   - created_at: timestamp (required, immutable) — server-side creation time
//   - status: string (required) — one of: "running", "complete", "error"
//   - progress: number (required) — 0-100
//   - critic: map (optional) — critic agent output
//   - market_research: map (optional) — market research agent output
//   - competitor_intel: map (optional) — competitor intel agent output
//   - financial_model: map (optional) — financial model agent output
//     - viability_score: number — 0-100
//     - viability_label: string
//     - viability_color: string — "green"|"amber"|"red"
//     - market_metrics: map
//     - score_breakdown: map
//   - assets: map (optional) — asset generator output
//
// Access Patterns:
//   - Backend (Admin SDK): create and update any report document
//   - Authenticated user: read their own report (uid == auth.uid)
//   - Anonymous sessions: report stored in sessionStorage only (no Firestore write)
//   - No user-to-user sharing of reports (private by design)
//   - No public read access
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default deny: deny ALL access unless explicitly allowed below ──
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helper Functions ──────────────────────────────────────────────

    // Check if the request comes from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user owns the document (by uid field)
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Check if the caller is setting their own UID on create
    function uidMatchesCaller() {
      return request.resource.data.uid == request.auth.uid;
    }

    // Prevent uid from being changed on update
    function uidNotModified() {
      return request.resource.data.uid == resource.data.uid;
    }

    // Validate that all required fields are present
    function hasRequiredReportFields(data) {
      return data.keys().hasAll(['uid', 'hypothesis', 'created_at', 'status', 'progress']);
    }

    // Validate the hypothesis string — must be 20–2000 chars, no PII injection
    function isValidHypothesis(data) {
      return data.hypothesis is string
          && data.hypothesis.size() >= 20
          && data.hypothesis.size() <= 2000;
    }

    // Validate the status enum
    function isValidStatus(data) {
      return data.status is string
          && data.status in ['running', 'complete', 'error'];
    }

    // Validate the progress field is a number in 0-100
    function isValidProgress(data) {
      return data.progress is number
          && data.progress >= 0
          && data.progress <= 100;
    }

    // Validate that created_at is a Firestore timestamp (not a string or user-forged date)
    function isValidCreatedAt(data) {
      return data.created_at is timestamp;
    }

    // Document-level validator — used in BOTH create AND update
    function isValidReport(data) {
      return hasRequiredReportFields(data)
          && data.uid is string
          && data.uid.size() > 0
          && data.uid.size() <= 128
          && isValidHypothesis(data)
          && isValidCreatedAt(data)
          && isValidStatus(data)
          && isValidProgress(data)
          // Enforce strict schema — no extra fields beyond the known set
          && data.keys().hasOnly([
              'uid', 'hypothesis', 'created_at', 'status', 'progress',
              'critic', 'market_research', 'competitor_intel',
              'financial_model', 'assets'
             ]);
    }

    // Validate that immutable fields (uid, created_at) are unchanged on update
    function immutableFieldsUnchanged() {
      return request.resource.data.uid == resource.data.uid
          && request.resource.data.created_at == resource.data.created_at
          && request.resource.data.hypothesis == resource.data.hypothesis;
    }

    // ── reports/{sessionId} Collection ───────────────────────────────
    match /reports/{sessionId} {

      // READ: Only the document owner can read their own report
      // This prevents any cross-user report access — PII in reports is protected
      allow read: if isAuthenticated() && isDocOwner();

      // CREATE: Only authenticated users may create a report for themselves
      // - uid must match caller (prevents creating a report "as" another user)
      // - Full schema validation applied
      // - created_at must be a server timestamp (type-enforced)
      allow create: if isAuthenticated()
                    && uidMatchesCaller()
                    && isValidReport(request.resource.data);

      // UPDATE: Only the document owner may update their own report
      // - uid and created_at and hypothesis are immutable after creation
      // - Full schema validation applied on every update
      // - Prevents an owner from corrupting their own document schema
      allow update: if isAuthenticated()
                    && isDocOwner()
                    && uidNotModified()
                    && immutableFieldsUnchanged()
                    && isValidReport(request.resource.data);

      // DELETE: Not allowed — reports are permanent records
      // If deletion is needed, backend Admin SDK handles it
      allow delete: if false;
    }
  }
}
