# Google AI / Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# App Config
PORT=8000
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
REQUIRE_AUTH=false

# Firebase Project
FIREBASE_PROJECT_ID=ai-startup-validator

# Optional: Google Cloud DLP for managed PII de-identification
DLP_PROJECT_ID=
DLP_LOCATION=global
